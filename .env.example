# Razorpay (get keys from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_secret_key

# JWT secret for auth sessions
JWT_SECRET=your-jwt-secret-min-32-chars

# MongoDB Atlas (optional — uses JSON files locally when unset)
# Create cluster at https://cloud.mongodb.com → Connect → Drivers → copy URI
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/astroknowledge?retryWrites=true&w=majority
